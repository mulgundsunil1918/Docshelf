# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # flutter_additional_ios_build_settings applies Flutter-specific
    # settings (SWIFT_VERSION etc.) — skip the share extension to avoid
    # conflicting SWIFT_VERSION values that break pod install.
    flutter_additional_ios_build_settings(target) unless target.name == 'DocShelfShareExtension'

    target.build_configurations.each do |config|
      # Force iOS 13.0 across every pod so older specs don't drag the
      # deployment target back down to 11/12 (Xcode 15 warns at build).
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # ─── permission_handler — opt out of unused permissions ────────
      # Each macro = one permission category we declare. Macros for
      # permissions we DON'T use must be set to 0 to avoid Apple's
      # "you declared X permission with no usage description" warning
      # at App Store review.
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',

        # Permissions we DO use:
        'PERMISSION_CAMERA=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_EVENTS=1',  # calendar (add_2_calendar / event store)

        # Permissions we DO NOT use — explicitly disabled:
        'PERMISSION_LOCATION=0',
        'PERMISSION_LOCATION_WHENINUSE=0',
        'PERMISSION_NOTIFICATIONS=0',
        'PERMISSION_MEDIA_LIBRARY=0',
        'PERMISSION_SPEECH_RECOGNIZER=0',
        'PERMISSION_BLUETOOTH=0',
        'PERMISSION_APP_TRACKING_TRANSPARENCY=0',
        'PERMISSION_CRITICAL_ALERTS=0',
        'PERMISSION_CONTACTS=0',
        'PERMISSION_REMINDERS=0',
        'PERMISSION_SENSORS=0',
      ].join(' ')

      # Strip bitcode (Apple deprecated it in Xcode 14).
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end

  # ── Fix: Xcode 15 ExtractAppIntentsMetadata cycle with app extensions ──
  # Xcode 15 added a build phase that scans embedded .appex files for App
  # Intents metadata. This creates a circular dependency: embedding the
  # share extension requires the phase to complete, but the phase needs the
  # extension to already be embedded. DocShelf doesn't use App Intents, so
  # we disable the scan entirely by setting APPINTENTS_SWIFT_LIBRARY_PATH
  # to empty on the Runner (main app) target in the main project.
  require 'xcodeproj'
  main_project_path = File.expand_path('../Runner.xcodeproj', __FILE__)
  main_project = Xcodeproj::Project.open(main_project_path)
  runner = main_project.targets.find { |t| t.name == 'Runner' }
  if runner
    runner.build_configuration_list.build_configurations.each do |c|
      c.build_settings['APPINTENTS_SWIFT_LIBRARY_PATH'] = ''
    end
    main_project.save
  end
end
